# ============================================================================
#  HR-помощник ТИУ — пример конфигурации.
#  Скопируйте в .env и заполните под своё окружение:
#    Linux/macOS:  cp .env.example .env
#    Windows:      copy .env.example .env
#  Имена переменных = поля config.py (регистр не важен).
# ============================================================================

# --- Базовое ------------------------------------------------------------------
# SECRET_KEY: длинная случайная строка (МИНИМУМ 16 символов!). Используется и для
# подписи cookie, и для шифрования персональных данных (PII). Сгенерировать:
#   Linux/macOS:  python -c "import secrets; print(secrets.token_hex(32))"
#   Windows PS:   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-min-16-chars
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Защита канала клиент↔сервер ──
# Сервер приложения слушает HTTP; TLS завершает обратный прокси (nginx/Caddy/Traefik).
# За HTTPS-прокси включите эти два — cookie сессии пойдёт только по HTTPS и браузер
# запомнит переход на HTTPS (HSTS шлётся автоматически при HTTPS-запросе):
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
# Заголовки безопасности (nosniff/anti-clickjacking/CSP). Если предпросмотр документов
# что-то блокирует — отключите строгий CSP: SECURITY_CSP=false
SECURITY_HEADERS=true
SECURITY_CSP=true

# ── Системные уведомления (Web Push) ──
# Требует `pip install pywebpush` и HTTPS (кроме localhost). Ключи VAPID можно оставить
# пустыми — сгенерируются автоматически в db/vapid.json. VAPID_SUBJECT — контакт админа.
VAPID_SUBJECT=mailto:admin@localhost
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# --- LLM (локальная GGUF-модель) ----------------------------------------------
# Путь к .gguf-файлу в models/. Без модели/при LLM_ENABLED=false — mock-ответы.
LLM_MODEL_PATH=./models/T-lite-it-2.1-Q4_K_M.gguf
LLM_ENABLED=true
# GPU-режим. true только если установлена CUDA-сборка llama-cpp-python (см. requirements).
LLM_USE_GPU=false
LLM_N_GPU_LAYERS=0
# Окно контекста (KV-cache ~1.5 ГБ на 16k для 8B Q4).
LLM_N_CTX=16384

# --- Qdrant (векторная БД) ----------------------------------------------------
# Локальный/нативный запуск:  http://localhost:6333
# Docker Compose (имя сервиса): http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hr_knowledge

# --- Эмбеддер -----------------------------------------------------------------
# Потоки ONNX-эмбеддера. 0 = авто (оставить одно ядро свободным), чтобы индексация
# большого документа не занимала весь CPU. Укажите число ядер для макс. скорости.
EMBED_THREADS=0

# --- OCR (Tesseract) ----------------------------------------------------------
# Путь к бинарю tesseract, ЕСЛИ он не в PATH (актуально для Windows).
# Linux/Docker: оставьте пустым — берётся из PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
OCR_LANGUAGES=rus+eng

# --- Конвертация старых форматов Office (.doc/.xls/.rtf/.odt → docx/xlsx) -------
# Требуется LibreOffice. В PATH — оставьте пусто. На Windows укажите путь к soffice.exe:
# SOFFICE_CMD=C:\Program Files\LibreOffice\program\soffice.exe
SOFFICE_CMD=
